{
  "name": "sistema-igl-credenciados",
  "version": "1.0.0",
  "description": "Sistema de cadastro e visualização de certificados IGL Coatings",
  "main": "server.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server.js",
    "client": "cd client && npm start",
    "build": "npm install && cd client && npm install && CI=false npm run build",
    "start": "node server.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "google-auth-library": "^8.9.0",
    "googleapis": "^126.0.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "igl",
    "coatings",
    "certificados",
    "garantia"
  ],
  "author": "IGL Coatings Brasil",
  "license": "MIT"
}
